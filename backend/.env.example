# Database
DATABASE_URL=mysql+aiomysql://root:root123@localhost:3306/english_coach?charset=utf8mb4

# AI Provider (claude | deepseek | glm)
# glm (智谱 GLM-4-Flash) 完全免费，推荐使用
AI_PROVIDER=glm
AI_API_KEY=your-zhipu-api-key-here

# ⚠️ 安全提示：生产环境部署时务必启用 HTTPS，否则 API Key 将以明文传输

# Redis (optional — cache auto-degrades when unavailable)
REDIS_URL=redis://localhost:6379/0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Auth (login credentials)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_EXPIRE_MINUTES=1440
